{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser-windows",
  "description": "Permissions for dynamically opened site browser WebviewWindows (labels browser-*)",
  "windows": ["browser-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "updater:default",
    "process:default"
  ]
}
