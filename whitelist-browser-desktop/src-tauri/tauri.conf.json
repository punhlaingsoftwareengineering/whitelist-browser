{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whitelist-browser-desktop",
  "version": "0.3.0",
  "identifier": "com.punhlainghospital.whitelist-browser-desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "whitelist-browser-desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5OTIzMDVCMkU3MUZCQjIKUldTeSszRXVXekNTMmJ3WDhyUU1HeENjUngrdnVLTmZZMEU4NHZFby93blQyNFByY1ZOcmRMbGEK",
      "endpoints": [
        "https://github.com/punhlaingsoftwareengineering/whitelist-browser/releases/latest/download/latest.json"
      ]
    }
  }
}

